[Unit]
Description=Marketplace homepage SQLite weekly statistics refresh
Documentation=README.md

[Service]
Type=oneshot
User=aoi
Group=aoi
WorkingDirectory=/home/aoi/services/auto-browser
ExecStart=/usr/bin/env npm run marketplace:home:db:maintain -- --analyze --json
StandardOutput=append:/home/aoi/services/auto-browser/artifacts/marketplace-homepage/db-maintenance.log
StandardError=append:/home/aoi/services/auto-browser/artifacts/marketplace-homepage/db-maintenance.err.log
